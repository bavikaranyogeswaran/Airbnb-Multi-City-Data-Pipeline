# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit it.

# ── Required ───────────────────────────────────────────────────────────────────

# Groq API key for LLM summaries and Text-to-SQL (AI Insights page).
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Optional ───────────────────────────────────────────────────────────────────

# Vite dev-server only — overrides the API proxy target when running
# `npm run dev` outside Docker. Has no effect inside the container
# (nginx handles /api proxying at runtime).
# API_TARGET=http://localhost:8000
